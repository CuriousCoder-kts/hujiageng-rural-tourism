.container {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 80vh;
    font-size: 40rpx;
    color: #888;
  }

  /* 轮播图样式 */
.swiper {
    height: 400rpx;
    background-color: #f0f0f0;
  }
  
  .swiper-image {
    width: 100%;
    height: 100%;
  }
  
  /* 信息卡片样式 */
  .info-card {
    padding: 30rpx;
    margin: 20rpx;
    background: white;
    border-radius: 16rpx;
    box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
  }
  
  .title {
    font-size: 40rpx;
    font-weight: bold;
    color: #333;
    text-align: center;
    margin-bottom: 30rpx;
  }
  
  .info-item {
    display: flex;
    align-items: flex-start;
    margin-bottom: 20rpx;
  }
  
  .icon {
    width: 36rpx;
    height: 36rpx;
    margin-right: 15rpx;
    margin-top: 6rpx;
  }
  
  .content {
    font-size: 28rpx;
    color: #555;
    line-height: 1.6;
  }
  
  /* 荣誉徽章 */
  .honors {
    display: flex;
    flex-wrap: wrap;
    margin-top: 30rpx;
  }
  
  .badge {
    background: #4CAF50;
    color: white;
    padding: 8rpx 20rpx;
    border-radius: 40rpx;
    font-size: 24rpx;
    margin-right: 15rpx;
    margin-bottom: 15rpx;
  }
  
  /* 视频区域 */
  .section-title {
    font-size: 34rpx;
    font-weight: bold;
    padding: 20rpx 30rpx;
    color: #333;
  }
  
  .village-video {
    width: 100%;
    height: 400rpx;
  }
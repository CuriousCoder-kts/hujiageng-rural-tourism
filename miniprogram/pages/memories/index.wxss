/* 容器样式 */
.container {
    background-color: #f8f9fa;
    height: 100vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  
  /* 扫码区域 */
  .scan-section {
    background: linear-gradient(135deg, #4CAF50, #2E7D32);
    padding: 30rpx;
    border-radius: 0 0 30rpx 30rpx;
    box-shadow: 0 8rpx 20rpx rgba(76, 175, 80, 0.3);
    position: relative;
    z-index: 10;
  }
  
  .scan-card {
    background: white;
    border-radius: 20rpx;
    padding: 30rpx;
    display: flex;
    flex-direction: column;
    align-items: center;
    box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.1);
  }
  
  .scan-icon {
    width: 100rpx;
    height: 100rpx;
    margin-bottom: 20rpx;
  }
  
  .scan-text {
    font-size: 36rpx;
    font-weight: bold;
    color: #333;
    margin-bottom: 10rpx;
  }
  
  .scan-tip {
    font-size: 26rpx;
    color: #666;
  }
  
  .scan-hint {
    text-align: center;
    margin-top: 20rpx;
    color: rgba(255,255,255,0.8);
    font-size: 26rpx;
    text-decoration: underline;
  }
  
  .scan-guide {
    background: rgba(255,255,255,0.9);
    border-radius: 16rpx;
    padding: 20rpx;
    margin-top: 20rpx;
    display: flex;
    flex-direction: column;
    align-items: center;
    animation: fadeIn 0.5s;
  }
  
  .guide-image {
    width: 200rpx;
    height: 200rpx;
    margin-bottom: 15rpx;
  }
  
  .guide-text {
    font-size: 28rpx;
    color: #333;
  }
  
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(20rpx); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  /* 分割线 */
  .divider {
    position: relative;
    height: 80rpx;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  
  .divider::before, .divider::after {
    content: "";
    position: absolute;
    top: 50%;
    width: 30%;
    height: 2rpx;
    background-color: #ddd;
  }
  
  .divider::before {
    left: 5%;
  }
  
  .divider::after {
    right: 5%;
  }
  
  .divider-text {
    background: #f8f9fa;
    padding: 0 30rpx;
    font-size: 30rpx;
    color: #666;
    position: relative;
    z-index: 1;
  }
  
  /* 加载状态 */
  .loading {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: #999;
  }
  
  .loading-icon {
    width: 80rpx;
    height: 80rpx;
    margin-bottom: 20rpx;
  }
  
  /* 故事列表 */
  .story-list {
    flex: 1;
    padding: 20rpx;
    overflow-y: auto;
    box-sizing: border-box;
  }
  
  .story-item {
    background: white;
    border-radius: 20rpx;
    padding: 30rpx;
    margin-bottom: 30rpx;
    box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.05);
  }
  
  .story-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 25rpx;
  }
  
  .story-title {
    font-size: 34rpx;
    font-weight: bold;
    color: #333;
  }
  
  .story-location {
    font-size: 26rpx;
    color: #888;
  }
  
  /* 音频控制 */
  .audio-control {
    display: flex;
    align-items: center;
    background-color: #f0f9ff;
    border-radius: 50rpx;
    padding: 20rpx 30rpx;
    margin-bottom: 25rpx;
  }
  
  .play-icon {
    width: 50rpx;
    height: 50rpx;
    margin-right: 20rpx;
  }
  
  .play-text {
    font-size: 30rpx;
    color: #2196F3;
    margin-right: 30rpx;
  }
  
  .progress-bar {
    flex: 1;
    height: 8rpx;
    background-color: #e0e0e0;
    border-radius: 4rpx;
    overflow: hidden;
  }
  
  .progress {
    height: 100%;
    background-color: #2196F3;
    border-radius: 4rpx;
    transition: width 0.3s;
  }
  
  /* 故事内容 */
  .story-content {
    font-size: 28rpx;
    color: #555;
    line-height: 1.6;
    margin-bottom: 25rpx;
  }
  
  /* 操作区域 */
  .story-actions {
    display: flex;
    border-top: 1rpx solid #eee;
    padding-top: 20rpx;
  }
  
  .action-btn {
    display: flex;
    align-items: center;
    margin-right: 40rpx;
  }
  
  .action-icon {
    width: 40rpx;
    height: 40rpx;
    margin-right: 10rpx;
  }
  
  .action-text {
    font-size: 26rpx;
    color: #666;
  }
  
  /* 空状态 */
  .empty {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 80rpx 0;
    color: #999;
  }
  
  .empty-icon {
    width: 200rpx;
    height: 200rpx;
    margin-bottom: 30rpx;
    opacity: 0.6;
  }
  
  .empty-text {
    font-size: 30rpx;
  }
/* 基础样式 */
page {
    background-color: #f8f9fa;
    font-size: 28rpx;
    color: #333;
  }
  
  .container {
    display: flex;
    flex-direction: column;
    height: 100vh;
    overflow: hidden;
    position: relative;
  }
  
  /* 视图切换器 */
  .view-switcher {
    display: flex;
    background-color: #fff;
    padding: 20rpx 0;
    box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
    z-index: 10;
    position: sticky;
    top: 0;
  }
  
  .switch-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 15rpx 0;
    font-size: 28rpx;
    color: #666;
    transition: all 0.3s;
  }
  
  .switch-item.active {
    color: #4CAF50;
    font-weight: 500;
    position: relative;
  }
  
  .switch-item.active::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 60%;
    height: 4rpx;
    background-color: #4CAF50;
    border-radius: 2rpx;
  }
  
  .switch-icon {
    width: 40rpx;
    height: 40rpx;
    margin-bottom: 8rpx;
  }
  
  /* 加载状态 */
  .loading-container {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background-color: #f8f9fa;
  }
  
  .loading-icon {
    width: 80rpx;
    height: 80rpx;
    margin-bottom: 20rpx;
  }
  
  .loading-text {
    font-size: 30rpx;
    color: #999;
  }
  
  /* 地图容器 */
  .map-container {
    position: relative;
    flex: 1;
    overflow: hidden;
    background-color: #e6f7ff;
  }
  
  .map {
    width: 100%;
    height: 100%;
  }
  
  .map-legend {
    position: absolute;
    bottom: 30rpx;
    left: 20rpx;
    background: rgba(255, 255, 255, 0.9);
    border-radius: 12rpx;
    padding: 12rpx 20rpx;
    display: flex;
    align-items: center;
    box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
    z-index: 10;
  }
  
  .legend-icon {
    width: 24rpx;
    height: 32rpx;
    margin: 0 8rpx 0 12rpx;
  }
  
  cover-text {
    font-size: 24rpx;
    color: #333;
    margin-right: 15rpx;
  }
  
  .add-button {
    position: absolute;
    bottom: 30rpx;
    right: 30rpx;
    background: #4CAF50;
    color: white;
    padding: 16rpx 28rpx;
    border-radius: 50rpx;
    display: flex;
    align-items: center;
    box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.2);
    z-index: 100;
    font-size: 28rpx;
    border: none;
    line-height: 1;
  }
  
  .add-button:active {
    transform: scale(0.95);
    opacity: 0.9;
  }
  
  .add-button::after {
    border: none;
  }
  
  .add-icon {
    width: 36rpx;
    height: 36rpx;
    margin-right: 8rpx;
  }
  
  /* 时间线容器 */
  .timeline-container {
    flex: 1;
    display: flex;
    flex-direction: column;
    background-color: #f8f9fa;
    padding: 20rpx 0;
  }
  
  .timeline-list {
    flex: 1;
    padding: 0 20rpx;
    box-sizing: border-box;
  }
  
  .add-card {
    background: white;
    border-radius: 16rpx;
    padding: 30rpx;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    margin-bottom: 25rpx;
    color: #4CAF50;
    border: 2rpx dashed #4CAF50;
    transition: all 0.2s;
  }
  
  .add-card:active {
    background-color: #f0f9f0;
  }
  
  .add-card .add-icon {
    width: 50rpx;
    height: 50rpx;
    margin-bottom: 15rpx;
  }
  
  .timeline-item {
    background: white;
    border-radius: 16rpx;
    padding: 25rpx;
    margin-bottom: 25rpx;
    box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
    display: flex;
    transition: transform 0.2s;
  }
  
  .timeline-item:active {
    transform: scale(0.98);
  }
  
  .timeline-date {
    width: 160rpx;
    border-right: 1rpx solid #eee;
    padding-right: 15rpx;
    margin-right: 15rpx;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
  }
  
  .date {
    font-size: 28rpx;
    font-weight: 500;
    color: #333;
    margin-bottom: 8rpx;
  }
  
  .duration {
    font-size: 24rpx;
    color: #888;
    background: #f0f0f0;
    padding: 4rpx 10rpx;
    border-radius: 16rpx;
  }
  
  .timeline-content {
    flex: 1;
  }
  
  .village-name {
    font-size: 32rpx;
    font-weight: 500;
    color: #333;
    margin-bottom: 15rpx;
    display: block;
  }
  
  .photos {
    display: flex;
    flex-wrap: wrap;
    margin-bottom: 15rpx;
    gap: 10rpx;
  }
  
  .photo {
    width: 180rpx;
    height: 180rpx;
    border-radius: 10rpx;
    background-color: #f0f0f0;
    flex-shrink: 0;
  }
  
  .more-photos {
    width: 180rpx;
    height: 180rpx;
    background: rgba(0,0,0,0.3);
    border-radius: 10rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 30rpx;
    font-weight: bold;
  }
  
  .note-container {
    margin-bottom: 15rpx;
  }
  
  .note {
    font-size: 26rpx;
    color: #555;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    overflow: hidden;
  }
  
  .favorite {
    display: flex;
    align-items: center;
    color: #FFC107;
    font-size: 24rpx;
  }
  
  .favorite-icon {
    width: 28rpx;
    height: 28rpx;
    margin-right: 6rpx;
  }
  
  .empty-timeline {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 80rpx 0;
    color: #999;
  }
  
  .empty-icon {
    width: 180rpx;
    height: 180rpx;
    margin-bottom: 25rpx;
    opacity: 0.6;
  }
  
  .empty-text {
    font-size: 30rpx;
    margin-bottom: 12rpx;
  }
  
  .empty-tip {
    font-size: 26rpx;
    color: #aaa;
  }
  
  /* 详情弹窗 */
  .detail-modal {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .modal-mask {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0,0,0,0.5);
  }
  
  .modal-content {
    position: relative;
    width: 85%;
    max-height: 85vh;
    background: white;
    border-radius: 20rpx;
    overflow: hidden;
    z-index: 1001;
    padding: 30rpx;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    animation: popup 0.3s ease;
  }
  
  @keyframes popup {
    from { transform: translateY(100rpx); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }
  
  .detail-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20rpx;
    padding: 2rpx 20rpx;
    margin-left: 5rpx;
  }
  
  .detail-header .village-name {
    font-size: 36rpx;
    font-weight: 500;
    color: #333;
    padding-left: 5rpx;
    margin-left: 5rpx;
    
  }
  
  .header-actions {
    display: flex;
    gap: 15rpx;
  }
  
  .action-btn {
    background: transparent;
    border: none;
    padding: 0;
    margin: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .action-btn::after {
    border: none;
  }
  
  .action-icon {
    width: 40rpx;
    height: 40rpx;
    transition: transform 0.2s;
  }
  
  .action-btn:active .action-icon {
    transform: scale(0.9);
  }
  
  .detail-date {
    display: flex;
    font-size: 26rpx;
    color: #666;
    margin-bottom: 20rpx;
    gap: 20rpx;
  }
  
  .detail-swiper {
    height: 360rpx;
    margin-bottom: 25rpx;
    border-radius: 14rpx;
    overflow: hidden;
    background-color: #f0f0f0;
  }
  
  .detail-image {
    width: 100%;
    height: 100%;
  }
  
  .section-title {
    font-size: 30rpx;
    font-weight: 500;
    color: #333;
    margin-bottom: 15rpx;
    display: block;
  }
  
  .note-content {
    font-size: 26rpx;
    color: #555;
    line-height: 1.6;
    max-height: 150rpx;
    overflow-y: auto;
  }
  
  .detail-map {
    margin-top: 25rpx;
  }
  
  .mini-map {
    width: 100%;
    height: 250rpx;
    border-radius: 14rpx;
    overflow: hidden;
  }
  
  /* 添加足迹表单 */
  .add-modal {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 20rpx;
    margin-bottom: 25rpx;
    border-bottom: 1rpx solid #eee;
  }
  
  .title {
    font-size: 34rpx;
    font-weight: 500;
    color: #333;
  }
  
  .close-btn {
    background: transparent;
    border: none;
    padding: 0;
    margin: 0;
  }
  
  .close-btn::after {
    border: none;
  }
  
  .close-icon {
    width: 36rpx;
    height: 36rpx;
    transition: transform 0.2s;
  }
  
  .close-btn:active .close-icon {
    transform: scale(0.9);
  }
  
  .form-content {
    max-height: 60vh;
    padding-bottom: 20rpx;
  }
  
  .form-item {
    margin-bottom: 35rpx;
  }
  
  .label {
    display: block;
    font-size: 28rpx;
    color: #333;
    margin-bottom: 12rpx;
    font-weight: 500;
  }
  
  .picker {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: #f8f9fa;
    border-radius: 10rpx;
    padding: 22rpx 25rpx;
    font-size: 26rpx;
    color: #333;
    transition: background-color 0.2s;
  }
  
  .picker:active {
    background-color: #f0f0f0;
  }
  
  .placeholder {
    color: #999;
  }
  
  .arrow {
    width: 22rpx;
    height: 22rpx;
  }
  
  .photos-container {
    display: flex;
    flex-wrap: wrap;
    gap: 15rpx;
  }
  
  .photo-item {
    position: relative;
    width: 180rpx;
    height: 180rpx;
  }
  
  .photo {
    width: 100%;
    height: 100%;
    border-radius: 10rpx;
    background-color: #f0f0f0;
  }
  
  .remove-btn {
    position: absolute;
    top: -10rpx;
    right: -10rpx;
    width: 36rpx;
    height: 36rpx;
    background: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    margin: 0;
    border: none;
    box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.2);
    z-index: 10;
  }
  
  .remove-btn::after {
    border: none;
  }
  
  .remove-icon {
    width: 20rpx;
    height: 20rpx;
  }
  
  .add-photo {
    width: 180rpx;
    height: 180rpx;
    background: #f8f9fa;
    border-radius: 10rpx;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: #999;
    font-size: 24rpx;
    border: none;
    padding: 0;
    margin: 0;
  }
  
  .add-photo::after {
    border: none;
  }
  
  .add-photo:active {
    background-color: #f0f0f0;
  }
  
  .add-photo .add-icon {
    width: 40rpx;
    height: 40rpx;
    margin-bottom: 10rpx;
  }
  
  .note-input {
    width: 100%;
    min-height: 180rpx;
    background: #f8f9fa;
    border-radius: 10rpx;
    padding: 20rpx;
    box-sizing: border-box;
    font-size: 26rpx;
    line-height: 1.5;
  }
  
  .word-count {
    text-align: right;
    font-size: 24rpx;
    color: #999;
    margin-top: 8rpx;
  }
  
  .form-actions {
    display: flex;
    justify-content: space-between;
    margin-top: 20rpx;
    gap: 20rpx;
  }
  
  .btn {
    flex: 1;
    height: 80rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 40rpx;
    font-size: 30rpx;
    transition: all 0.2s;
    border: none;
  }
  
  .btn::after {
    border: none;
  }
  
  .cancel {
    background: #f0f0f0;
    color: #666;
  }
  
  .cancel:active {
    background: #e0e0e0;
  }
  
  .submit {
    background: #4CAF50;
    color: white;
  }
  
  .submit:active {
    background: #3d8b40;
  }
  
  /* 防止弹窗滚动穿透 */
  .prevent-scroll {
    overflow: hidden;
    height: 100vh;
  }
  
  /* --- 地标详情弹窗样式 --- */
  .detail-modal .modal-content {
    height: 80vh;
    display: flex;
    flex-direction: column;
    padding: 30rpx 0 0;
  }
  
  .detail-modal .modal-content .section-title {
    font-size: 32rpx;
    font-weight: bold;
    color: #333;
    margin-bottom: 20rpx;
    position: relative;
    padding-left: 16rpx;
  }
  
  .detail-modal .modal-content .section-title::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 8rpx;
    height: 36rpx;
    background-color: #4CAF50;
    border-radius: 4rpx;
  }
  
  .detail-modal .modal-content > .detail-header,
  .detail-modal .modal-content > .detail-date,
  .detail-modal .modal-content > .detail-swiper,
  .detail-modal .modal-content > .detail-note,
  .detail-modal .modal-content > .detail-map {
    padding-left: 28rpx;
    padding-right: 28rpx;
  }
  
  .detail-modal .modal-content > .detail-swiper {
    margin-bottom: 28rpx;
    border-radius: 18rpx;
  }
  
  .detail-modal .modal-content > .detail-date {
    margin-bottom: 18rpx;
  }
  
  .detail-modal .modal-content > .detail-note {
    margin-bottom: 24rpx;
  }
  
  .detail-modal .modal-content > .detail-map {
    margin-top: 24rpx;
  }
  
  .detail-modal .modal-content .divider {
    margin: 28rpx 0;
  }
  
  .detail-modal .modal-content .note-content {
    font-size: 26rpx;
    color: #555;
    line-height: 1.8;
    max-height: 180rpx;
    overflow-y: auto;
    background: #f8f9fa;
    border-radius: 10rpx;
    padding: 18rpx;
  }
  
  .detail-modal .modal-content .mini-map {
    border-radius: 18rpx;
    margin-top: 12rpx;
  }
  
  /* 用户足迹模块 */
  .user-section .user-footprint {
    background-color: #f7f7f7;
    border-radius: 16rpx;
    padding: 24rpx;
    margin-bottom: 10rpx;
  }
  
  .user-section .user-photos {
    display: flex;
    flex-wrap: wrap;
    gap: 10rpx;
    margin-bottom: 18rpx;
  }
  
  .user-section .user-photo-thumb {
    width: 180rpx;
    height: 180rpx;
    border-radius: 8rpx;
  }
  
  .user-section .user-note {
    display: block;
    font-size: 28rpx;
    color: #555;
    margin-bottom: 10rpx;
    font-style: italic;
  }
  
  .user-section .user-visit-date {
    font-size: 24rpx;
    color: #999;
    text-align: right;
  }
  
  /* 未点亮时的提示 */
  .no-footprint {
    text-align: center;
    padding: 40rpx 0;
  }
  
  .no-footprint text {
    display: block;
    color: #888;
    margin-bottom: 30rpx;
  }
  
  .add-footprint-btn {
    background-color: #4CAF50;
    color: white;
    border-radius: 30rpx;
    padding: 5rpx;
    font-size: 34rpx;
  }
  
  .detail-scroll-content {
    flex: 1;
    overflow-y: auto;
    padding: 0 28rpx 30rpx;
    box-sizing: border-box;
  }
  
  .official-section .description {
    font-size: 28rpx;
    color: #666;
    line-height: 2.0;
    margin: 18rpx 0 0 0;
    text-align: left;
  }
  
  .detail-section.user-section {
    margin-top: 36rpx;
  }